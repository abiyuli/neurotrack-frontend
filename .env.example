# URL base del API Gateway (sin trailing slash)
# Ejemplo: https://xxxxxxxxxx.execute-api.us-east-2.amazonaws.com/v1
VITE_API_BASE_URL=https://u4j6cydbyf.execute-api.us-east-2.amazonaws.com/v1
VITE_COGNITO_REGION=us-east-2
VITE_COGNITO_CLIENT_ID=your_cognito_app_client_id
VITE_TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key
# TURNSTILE_SECRET_KEY → va SOLO en el backend (variable de entorno Lambda), nunca en el frontend
