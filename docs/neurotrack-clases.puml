  ClassBackgroundColor White
  ClassBorderColor       #1D4E89
  PackageBorderColor     #378ADD
  PackageBackgroundColor #F0F6FF
  ArrowColor             #0B2545
  NoteBorderColor        #D97706
  NoteBackgroundColor    #FFFBEB
