hide empty members

' ══════════════════════════════════════════════════════════
' 1. ENTIDADES DynamoDB
' ══════════════════════════════════════════════════════════
package "DynamoDB — Entidades" #EEF4FF {

  class MotorEvent <<entity>> {
    ' Clave compuesta
    + PK         : String  // SESSION#{session_id}
    + SK         : String  // {module}#{timestamp}
    ' Comunes
    + event_id   : String
    + patient_id : String  <<GSI-hash>>
    + session_id : String
    + device_id  : String
    + timestamp  : Long    <<GSI-sort>>
    + module     : String  // tremor | fog | bradykinesia
    + type       : String  // (Schema B: brady_event)
    + alert      : Boolean
    + alert_flag : String  // (Schema B: "true"/"false")
    + firmware_version : String
    ==Tremor==
    + tremor_class     : String // rest|essential (A) / leve|moderado|severo (B)
    + severity         : String // alias Schema A
    + tremor_frequency : Float
    + frequency        : Float  // alias
    + tremor_amplitude : Float
    + amplitude        : Float  // alias
    + accel_x : Float  // Schema A — campos planos
    + accel_y : Float
    + accel_z : Float
    + accel   : Map    // Schema B — {x, y, z}
    ==FOG==
    + fog_class       : String // (Schema B)
    + prediction      : String // (Schema A)
    + fog_probability : Float  // 0.0–1.0
    + event_start     : Long
    + event_end       : Long
    + duration_ms     : Long
    ==Bradykinesia==
    + movement              : String // Schema B: finger_tapping|...
    + test_type             : String // Schema A: fingertapping|...
    + medication            : String // Schema A
    + medication_condition  : String // Schema B
    + velocity              : Float  // mm/s
    + mean_velocity         : Float
    + movement_speed        : Float  // Schema B alias
    + movement_amplitude    : Float  // Schema B alias
    + total_taps_left       : Int
    + total_taps_right      : Int
    + tap_frequency_left    : Float
    + tap_frequency_right   : Float
    + mean_amplitude_left   : Float
    + mean_amplitude_right  : Float
    + amplitude_variability : Float
    + decrement_5  : Float
    + decrement_7  : Float
    + decrement_10 : Float
  }

  class Patient <<entity>> {
    + patient_id         : String <<PK>>
    + nombre             : String
    + edad               : Int
    + dni                : String
    + telefono           : String
    + medico_id          : String <<GSI-hash>>
    + cuidador_id        : String <<GSI-hash>>
    + medicacion         : String
    + dosis              : String
    + diagnostico        : String
    + tiempo_diagnostico : String
    + estado             : String // Activo | Inactivo
    + comorbilidades     : String
    + fecha_registro     : String // YYYY-MM-DD
  }

  class Session <<entity>> {
    + PK         : String // PATIENT#{patient_id}
    + SK         : String // SESSION#{session_id}
    + patient_id : String
    + session_id : String <<GSI-hash>>
    + start_time : String // ISO 8601
    + status     : String // completed | active
    + mode       : String
    + device_id  : String
    + sampling_rate : Int // Hz
    + modules    : List<String>
    ' ⚠ Sin escritor activo — 13 ítems seed
  }

  class ModuleMetrics <<entity>> {
    + PK        : String // SESSION#{session_id}
    + SK        : String // METRICS#{module}#{ts}
    + patient_id : String
    + module    : String
    + window_start : Long
    + window_end   : Long
    ' ⚠ 0 ítems — diseño Anexo F sin implementar
  }

  class AuditEntry <<entity>> {
    + PK          : String // AUDIT#{YYYY-MM-DD}
    + SK          : String
    + admin_email : String
    + operation   : String // login|create|update|delete|export
    + target      : String
    + timestamp   : String
  }

  class NeurotrackUser <<entity>> {
    + PK    : String
    + SK    : String
    + email : String
    + role  : String // medico|cuidador|paciente|investigador|admin
  }

}

' ══════════════════════════════════════════════════════════
' 2. DTOs — tipos normalizados que produce Lambda
' ══════════════════════════════════════════════════════════
package "DTOs — Output normalizado de Lambda" #FFF9EC {

  class TremorEvent <<dto>> {
    + timestamp    : String
    + severity     : String // normal|rest|essential|leve|moderado|severo
    + frequency    : Float  // Hz
    + amplitude    : Float  // m/s²
    + acceleration : Float  // magnitud √(x²+y²+z²)
    + accel_x : Float
    + accel_y : Float
    + accel_z : Float
  }

  class FogEvent <<dto>> {
    + timestamp       : String
    + prediction      : String // normal | freeze
    + fog_probability : Float  // 0.0–1.0
    + event_start     : Long
    + event_end       : Long
    + duration_ms     : Long
    + accel           : Map    // {x, y, z}
  }

  class BradyEvent <<dto>> {
    + timestamp    : String
    + session_id   : String
    + test_type    : String  // fingertapping|handopening|pronationsupination|unknown
    + medication   : String  // ON | OFF
    + velocity     : Float
    + amplitude    : Float
    + frequency    : Float
    + mean_velocity : Float
    + total_taps_left       : Int
    + total_taps_right      : Int
    + tap_frequency_left    : Float
    + tap_frequency_right   : Float
    + mean_amplitude_left   : Float
    + mean_amplitude_right  : Float
    + amplitude_variability : Float
    + decrement_5  : Float
    + decrement_7  : Float
    + decrement_10 : Float
  }

  class SessionData <<dto>> {
    + tremor       : List<TremorEvent>
    + fog          : List<FogEvent>
    + bradykinesia : List<BradyEvent>
  }

  class AlertEntry <<dto>> {
    + patient_id : String
    + module     : String
    + timestamp  : Long
    + time       : String  // relativo ("Hace 3h")
    + detail     : String
    + type       : String  // label legible
    + level      : String  // high | medium | low
    + typeClass  : String  // "ft-trem" | "ft-fog" | "ft-brad"
  }

  class PatientIndicators <<dto>> {
    + patient_id    : String
    + totalAlerts   : Int
    + activeModules : Int
    + lastSession   : String
    + modules       : List<ModuleChip>
    + history       : List<SessionChip>
  }

  class ModuleChip <<dto>> {
    + name      : String
    + dotClass  : String
    + chipClass : String // ac-ok | ac-warn | ac-danger
    + chipLabel : String
  }

  class SessionChip <<dto>> {
    + date      : String // "DD/MM"
    + chipClass : String
    + chipLabel : String
  }

  SessionData *-- TremorEvent
  SessionData *-- FogEvent
  SessionData *-- BradyEvent
  PatientIndicators *-- ModuleChip
  PatientIndicators *-- SessionChip
}

' ══════════════════════════════════════════════════════════
' 3. BACKEND — Lambda Services
' ══════════════════════════════════════════════════════════
package "Backend — Lambda Services" #ECFDF5 {

  class SessionsLambda <<lambda>> {
    - events_table : DynamoDB
    + lambda_handler(event) : Response
    --Normalización dual-schema--
    + norm_tremor_class(val) : String
    + norm_fog_prediction(val) : String
    + norm_test_type(val) : String
    + get_accel(evt) : Tuple<x,y,z>
    --Detección de módulo--
    + is_fog(evt) : Boolean
    + is_tremor(evt) : Boolean
    + is_brady(evt) : Boolean
    ..
    GET /sessions/{patient_id}?start_date&end_date
  }

  class PatientsLambda <<lambda>> {
    - patients_table : DynamoDB
    + get_patients(event) : Response
    + create_patient(event) : Response
    + update_patient(event) : Response
    ..
    GET /patients
    POST /patients
    PUT /patients/{patient_id}
  }

  class CuidadorLambda <<lambda>> {
    - patients_table : DynamoDB
    - events_table   : DynamoDB
    + get_patients(cuidador_id) : Response
    + get_indicators(patient_id) : Response
    + get_alerts(cuidador_id) : Response
    --Helpers de datos--
    + _last_event(patient_id) : MotorEvent
    + _active_modules(patient_id) : List<String>
    + _count_alerts(patient_id, module) : Int
    + _session_history(patient_id, n) : List<SessionChip>
    --Helpers de alertas--
    + _alert_level(mod) : String // high|medium|low
    + _build_detail(ev) : String
    --Helpers de formato--
    + _fmt_relative(ts) : String
    + _fmt_date_ms(ts) : String
    ..
    GET /cuidador/patients
    GET /cuidador/patients/{id}/indicators
    GET /cuidador/alerts
  }

  class AdminLambda <<lambda>> {
    - patients_table : DynamoDB
    - audit_table    : DynamoDB
    - dynamo         : DynamoResource
    + get_usuarios() : Response
    + get_dashboard() : Response
    + post_asignacion(cuidador, patient) : Response
    + delete_asignacion(cuidador_email) : Response
    + get_audit() : Response
    ..
    GET/POST/PUT/DELETE /admin/*
  }

  class AuthLambda <<lambda>> {
    - cognito : CognitoIdp
    + login(email, password) : Tokens
    ..
    POST /auth/login
  }

  class RegisterLambda <<lambda>> {
    - cognito : CognitoIdp
    + register(body) : Response
    ..
    POST /register
  }

  class MeLambda <<lambda>> {
    - cognito : CognitoIdp
    + get_me(claims) : UserProfile
    ..
    GET /me
  }

  class PacienteLambda <<lambda>> {
    - events_table : DynamoDB
    + get_alertas(patient_id) : Response
    + get_dashboard(patient_id) : Response
    + get_sesiones(patient_id) : Response
    ..
    GET /paciente/alertas
    GET /paciente/dashboard
    GET /paciente/sesiones
  }

  class InvestigadorLambda <<lambda>> {
    - events_table : DynamoDB
    + get_sesiones(params) : Response
    + get_metricas(sesId) : Response
    + exportar_csv(params) : Response
    + poll_job(jobId) : Response
    ..
    GET /investigador/sesiones
    GET /investigador/sesiones/{id}/metricas
    GET /investigador/exportar
    GET /investigador/exportar/jobs/{jobId}
  }

}

